# 走天下 travel-guide 环境变量示例
# 复制为 .env.local 并填入真实值即可
# 真实 .env.local 不要提交到 git

# 数据库（Postgres）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/travel_dev?schema=public

# 童慧行统一 token 校验密钥（与 auth-service 共享）
AUTH_SERVICE_JWT_SECRET=change_me_in_production

# 阿里云 OSS（附录 F）
ALIYUN_OSS_BUCKET=grandkidsgo-travel
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_STS_ACCESS_KEY_ID=change_me
ALIYUN_STS_ACCESS_KEY_SECRET=change_me

# AI Provider 抽象层（附录 E）
# 三个值可选：siliconflow | openai_compatible | mock
# 开发期可留 mock（无需 key）；生产必须 siliconflow 或 openai_compatible
AI_PROVIDER=mock

# SiliconFlow（推荐）
SILICONFLOW_API_KEY=
SILICONFLOW_ENDPOINT=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# OpenAI 兼容
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_ENDPOINT=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini

# 走天下主站 CORS（apps/main-site 调用）
CORS_ALLOWED_ORIGINS=https://grandand.com,https://travel.grandand.com

# 服务端口
PORT=3010
